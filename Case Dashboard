</div>
))}
</div>
</div>
);
}

// ── AGENDA ────────────────────────────────────────────────────────────────────
function AgendaView({cases,onSelect}) {
const sorted=cases.filter(c=>c.nextDeadline).sort((a,b)=>new Date(a.nextDeadline)-new Date(b.nextDeadline));
const grouped={};
sorted.forEach(c=>{
const d=daysUntil(c.nextDeadline);
const k=d<0?“⚠ OVERDUE”:d===0?“TODAY”:d<=7?“THIS WEEK”:d<=14?“NEXT WEEK”:d<=31?“THIS MONTH”:“LATER”;
if(!grouped[k])grouped[k]=[];
grouped[k].push(c);
});
const ORDER=[“⚠ OVERDUE”,“TODAY”,“THIS WEEK”,“NEXT WEEK”,“THIS MONTH”,“LATER”];
const GC={“⚠ OVERDUE”:”#EF4444”,“TODAY”:”#F59E0B”,“THIS WEEK”:”#F59E0B”,“NEXT WEEK”:”#6B8CFF”,“THIS MONTH”:”#A78BFA”,“LATER”:”#6B7280”};
return (
<div style={{maxWidth:860}}>
{ORDER.filter(k=>grouped[k]).map(k=>(
<div key={k} style={{marginBottom:20}}>
<div style={{display:“flex”,alignItems:“center”,gap:8,marginBottom:8}}>
<div style={{height:1,width:18,background:GC[k]}}/>
<span style={{fontSize:10,letterSpacing:”.12em”,color:GC[k],fontWeight:500}}>{k}</span>
<div style={{height:1,flex:1,background:”#1E2029”}}/>
<span style={{fontSize:10,color:”#6B7280”}}>{grouped[k].length}</span>
</div>
{grouped[k].map(c=>(
<div key={c._id} onClick={()=>onSelect(c)} style={{background:”#111318”,border:`1px solid #1E2029`,borderLeft:`3px solid ${STAGE_COLORS[c.stage]}`,borderRadius:4,marginBottom:5,padding:“10px 13px”,display:“grid”,gridTemplateColumns:“80px 1fr auto”,gap:12,alignItems:“start”,cursor:“pointer”,transition:“background .1s”}}
onMouseEnter={e=>e.currentTarget.style.background=”#161820”}
onMouseLeave={e=>e.currentTarget.style.background=”#111318”}>
<div>
<div style={{fontSize:9,color:”#C8A84B”}}>{c.id}</div>
<div style={{fontSize:9,color:”#6B7280”,marginTop:2}}>{c.nextDeadline}</div>
</div>
<div>
<div style={{fontSize:12,color:”#C8CDD8”,marginBottom:3}}>{c.caption}</div>
{c.nextAction&&<div style={{fontSize:10,color:”#8892A0”,marginBottom:5}}>↳ {c.nextAction}</div>}
{c.pendingItems.length>0&&<div style={{display:“flex”,gap:5,flexWrap:“wrap”}}>{c.pendingItems.map((x,i)=><span key={i} style={{fontSize:9,background:”#1A1E28”,border:“1px solid #2A2D38”,borderRadius:2,padding:“2px 6px”,color:”#8892A0”}}>{x}</span>)}</div>}
</div>
<div style={{textAlign:“right”}}>
<span style={{fontSize:9,padding:“2px 7px”,borderRadius:2,background:STAGE_COLORS[c.stage]+“22”,color:STAGE_COLORS[c.stage],display:“block”,marginBottom:4}}>{c.stage}</span>
<span style={{fontSize:9,color:”#6B7280”}}>{c.partner}</span>
</div>
</div>
))}
</div>
))}
{sorted.length===0&&<div style={{textAlign:“center”,color:”#6B7280”,padding:32,fontSize:12}}>No upcoming deadlines.</div>}
</div>
);
}

// ── DETAIL MODAL ──────────────────────────────────────────────────────────────
