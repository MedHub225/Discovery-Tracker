<div style={{fontSize:10,color:”#8892A0”}}>{(c.nextAction||””).slice(0,40)}{(c.nextAction||””).length>40?”…”:””}</div>
<div><Badge dateStr={c.nextDeadline}/></div>
<div><span style={{fontSize:9,padding:“2px 6px”,borderRadius:2,background:STAGE_COLORS[c.stage]+“22”,color:STAGE_COLORS[c.stage]}}>{c.stage.slice(0,9)}</span></div>
<div style={{fontSize:10,color:”#8892A0”}}>{c.partner}</div>
<div style={{fontSize:10,color:”#8892A0”}}>{c.county}</div>
