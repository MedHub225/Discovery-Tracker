{cases.map((c,i)=>(
<div key={c._id} className=“row” onClick={()=>onSelect(c)} style={{display:“grid”,gridTemplateColumns:C,padding:“9px 13px”,borderBottom:“1px solid #1A1D26”,background:i%2===0?”#0D0F14”:”#111318”,alignItems:“center”,cursor:“pointer”,transition:“background .1s”}}>
