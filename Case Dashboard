<div style={{display:“flex”,gap:9,overflowX:“auto”,paddingBottom:12}}>
{STAGES.map(stage=>(
<div key={stage} style={{background:”#111318”,border:“1px solid #1E2029”,borderRadius:5,minWidth:195,width:195,flexShrink:0}}>
<div style={{padding:“8px 10px”,borderBottom:“1px solid #1E2029”,display:“flex”,alignItems:“center”,justifyContent:“space-between”}}>
<div style={{display:“flex”,alignItems:“center”,gap:6}}>
<div style={{width:7,height:7,borderRadius:“50%”,background:STAGE_COLORS[stage]}}/>
<span style={{fontSize:9,letterSpacing:”.07em”,color:”#C8CDD8”}}>{stage.toUpperCase()}</span>
</div>
<span style={{fontSize:11,color:”#6B7280”}}>{groups[stage].length}</span>
</div>
<div style={{padding:“6px 0”,maxHeight:“calc(100vh - 310px)”,overflowY:“auto”}}>
{groups[stage].length===0 && <div style={{padding:12,fontSize:10,color:”#6B7280”,textAlign:“center”}}>—</div>}
{groups[stage].map(c=>(
<div key={c._id} onClick={()=>onSelect(c)} style={{background:”#161820”,border:“1px solid #1E2029”,borderRadius:3,margin:“0 7px 7px”,padding:“9px 10px”,cursor:“pointer”,transition:“all .1s”}}
onMouseEnter={e=>{e.currentTarget.style.borderColor=”#C8A84B55”;e.currentTarget.style.background=”#1A1E28”}}
onMouseLeave={e=>{e.currentTarget.style.borderColor=”#1E2029”;e.currentTarget.style.background=”#161820”}}>
<div style={{fontSize:9,color:”#6B7280”,marginBottom:3}}>{c.id} · {c.county}</div>
<div style={{fontSize:11,color:”#C8CDD8”,lineHeight:1.4,marginBottom:4}}>{c.caption}</div>
<div style={{fontSize:9,color:”#8892A0”,marginBottom:5}}>{c.type}</div>
<div style={{display:“flex”,justifyContent:“space-between”,alignItems:“center”}}>
<Badge dateStr={c.nextDeadline}/>
<span style={{fontSize:9,color:c.priority===“High”?”#EF4444”:c.priority===“Medium”?”#F59E0B”:”#6B7280”}}>{c.priority===“High”?“●HI”:c.priority===“Medium”?“●MD”:“○LO”}</span>
</div>
{c.nextAction&&<div style={{marginTop:5,fontSize:9,color:”#8892A0”,borderTop:“1px solid #1E2029”,paddingTop:4}}>↳ {c.nextAction.slice(0,48)}</div>}
</div>
))}
</div>
</div>
))}
</div>
);
}

// ── LIST ──────────────────────────────────────────────────────────────────────
