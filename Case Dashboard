<div style={{display:“grid”,gridTemplateColumns:“1fr 1fr”,gap:7,marginBottom:14}}>
{[
{l:“Stage”,v:c.stage,col:STAGE_COLORS[c.stage]},
{l:“Priority”,v:c.priority,col:c.priority===“High”?”#EF4444”:c.priority===“Medium”?”#F59E0B”:”#6B7280”},
{l:“Partner”,v:c.partner,col:”#C8CDD8”},
{l:“Date Opened”,v:c.openDate||”—”,col:”#C8CDD8”},
{l:“Next Deadline”,v:c.nextDeadline||”—”,col:d!==null&&d<0?”#EF4444”:d!==null&&d<=7?”#F59E0B”:”#34D399”},
{l:“Court Date”,v:c.courtDate||“TBD”,col:”#C8CDD8”},
].map(r=>(
<div key={r.l} style={{background:”#0D0F14”,border:“1px solid #1E2029”,borderRadius:3,padding:“8px 11px”}}>
<div style={{fontSize:9,color:”#6B7280”,letterSpacing:”.1em”,marginBottom:2}}>{r.l.toUpperCase()}</div>
<div style={{fontSize:12,color:r.col,fontWeight:500}}>{r.v}</div>
</div>
))}
</div>
{c.nextAction&&<div style={{marginBottom:12}}>
<div style={{fontSize:9,color:”#6B7280”,letterSpacing:”.1em”,marginBottom:5}}>NEXT ACTION</div>
<div style={{background:”#0D0F14”,borderLeft:“3px solid #C8A84B”,border:“1px solid #C8A84B33”,borderRadius:3,padding:“9px 11px”,fontSize:12,color:”#C8CDD8”}}>{c.nextAction}</div>
</div>}
{c.pendingItems.length>0&&<div style={{marginBottom:12}}>
<div style={{fontSize:9,color:”#6B7280”,letterSpacing:”.1em”,marginBottom:5}}>PENDING ITEMS</div>
{c.pendingItems.map((x,i)=>(
<div key={i} style={{display:“flex”,alignItems:“center”,gap:8,background:”#0D0F14”,border:“1px solid #1E2029”,borderRadius:3,padding:“6px 11px”,marginBottom:3}}>
<div style={{width:11,height:11,border:“1px solid #2A2D38”,borderRadius:2,flexShrink:0}}/>
<span style={{fontSize:11,color:”#C8CDD8”}}>{x}</span>
</div>
))}
</div>}
{c.notes&&<div style={{marginBottom:12}}>
<div style={{fontSize:9,color:”#6B7280”,letterSpacing:”.1em”,marginBottom:5}}>NOTES</div>
<div style={{background:”#0D0F14”,border:“1px solid #1E2029”,borderRadius:3,padding:“9px 11px”,fontSize:11,color:”#8892A0”,lineHeight:1.7,whiteSpace:“pre-wrap”}}>{c.notes}</div>
</div>}
<div style={{marginTop:14}}>
<div style={{fontSize:9,color:”#6B7280”,letterSpacing:”.1em”,marginBottom:5}}>DISCOVERY PROGRESS</div>
<div style={{display:“flex”,gap:3}}>
{STAGES.filter(s=>s!==“Closed”).map(s=>{
const idx=STAGE_ORDER[s],cur=STAGE_ORDER[c.stage],isA=s===c.stage,isPast=idx<cur;
return <div key={s} style={{flex:1}}><div style={{height:3,borderRadius:2,background:isA?STAGE_COLORS[s]:isPast?STAGE_COLORS[s]+“55”:”#1E2029”}}/>{isA&&<div style={{fontSize:7,color:STAGE_COLORS[s],marginTop:2,textAlign:“center”}}>{s}</div>}</div>;
})}
</div>
</div>
</div>
</div>
);
}

// ── CASE FORM ─────────────────────────────────────────────────────────────────
function CaseForm({initial,onSave,onClose}) {
const [f,setF]=useState({…initial,pendingItems:Array.isArray(initial.pendingItems)?initial.pendingItems.join(”\n”):initial.pendingItems||””});
const s=(k,v)=>setF(x=>({…x,[k]:v}));
const [saving,setSaving]=useState(false);
const submit=async()=>{
if(!f.caption.trim()){alert(“Caption is required.”);return;}
setSaving(true);
await onSave({…f,pendingItems:f.pendingItems.split(”\n”).filter(Boolean)});
setSaving(false);
};
const Label=({t})=><label style={{fontSize:9,letterSpacing:”.1em”,color:”#6B7280”,display:“block”,marginBottom:5}}>{t}</label>;
const Row=({children,cols=1})=><div style={{display:“grid”,gridTemplateColumns:`repeat(${cols},1fr)`,gap:11,marginBottom:12}}>{children}</div>;
const Btn=({label,primary,onClick,disabled})=>(
<button onClick={onClick} disabled={disabled} style={{background:primary?”#C8A84B”:”#161820”,border:`1px solid ${primary?"#C8A84B":"#2A2D38"}`,color:primary?”#0D0F14”:”#C8CDD8”,padding:“7px 16px”,borderRadius:3,cursor:“pointer”,fontFamily:”‘DM Mono’,monospace”,fontSize:11,letterSpacing:”.05em”,fontWeight:primary?500:400}}>
{label}
</button>
);
return (
<div onClick={onClose} style={{position:“fixed”,inset:0,background:“rgba(0,0,0,.75)”,zIndex:200,display:“flex”,alignItems:“center”,justifyContent:“center”,padding:16}}>
<div onClick={e=>e.stopPropagation()} style={{background:”#111318”,border:“1px solid #2A2D38”,borderRadius:6,width:“100%”,maxWidth:660,maxHeight:“90vh”,overflowY:“auto”,padding:26}}>
<div style={{display:“flex”,justifyContent:“space-between”,alignItems:“center”,marginBottom:18}}>
<div style={{fontFamily:”‘Playfair Display’,serif”,fontSize:15,color:”#E8DFC0”}}>{initial._id?“Edit Case”:“New Case”}</div>
<button onClick={onClose} style={{background:“none”,border:“none”,color:”#6B7280”,cursor:“pointer”,fontSize:20}}>×</button>
</div>
<Row cols={2}><div><Label t="CASE ID"/><input value={f.id} onChange={e=>s(“id”,e.target.value)}/></div><div><Label t="CAPTION (STYLE) *"/><input value={f.caption} onChange={e=>s(“caption”,e.target.value)} placeholder=“Smith v. Acme Corp.”/></div></Row>
<Row cols={3}>
<div><Label t="CASE TYPE"/><select value={f.type} onChange={e=>s(“type”,e.target.value)}>{TYPES.map(t=><option key={t}>{t}</option>)}</select></div>
<div><Label t="COUNTY"/><select value={f.county} onChange={e=>s(“county”,e.target.value)}>{COUNTIES.map(c=><option key={c}>{c}</option>)}</select></div>
<div><Label t="PARTNER"/><select value={f.partner} onChange={e=>s(“partner”,e.target.value)}>{PARTNERS.map(p=><option key={p}>{p}</option>)}</select></div>
</Row>
<Row cols={3}>
<div><Label t="STAGE"/><select value={f.stage} onChange={e=>s(“stage”,e.target.value)}>{STAGES.map(st=><option key={st}>{st}</option>)}</select></div>
<div><Label t="PRIORITY"/><select value={f.priority} onChange={e=>s(“priority”,e.target.value)}>{[“High”,“Medium”,“Low”].map(p=><option key={p}>{p}</option>)}</select></div>
<div><Label t="DATE OPENED"/><input type=“date” value={f.openDate||””} onChange={e=>s(“openDate”,e.target.value)}/></div>
</Row>
<Row cols={2}><div><Label t="NEXT DEADLINE"/><input type=“date” value={f.nextDeadline||””} onChange={e=>s(“nextDeadline”,e.target.value)}/></div><div><Label t="COURT DATE"/><input type=“date” value={f.courtDate||””} onChange={e=>s(“courtDate”,e.target.value)}/></div></Row>
<Row><div><Label t="NEXT ACTION"/><input value={f.nextAction} onChange={e=>s(“nextAction”,e.target.value)} placeholder=“e.g. Depose plaintiff’s treating physician”/></div></Row>
<Row><div><Label t="PENDING ITEMS (one per line)"/><textarea value={f.pendingItems} onChange={e=>s(“pendingItems”,e.target.value)} rows={4} placeholder={“Respond to discovery demands\nSchedule expert IME”}/></div></Row>
<Row><div><Label t="NOTES"/><textarea value={f.notes||””} onChange={e=>s(“notes”,e.target.value)} rows={3} placeholder=“Internal notes, strategy, settlement posture…”/></div></Row>
<div style={{display:“flex”,gap:8,justifyContent:“flex-end”}}>
<Btn label="Cancel" onClick={onClose}/>
<Btn label={saving?“Saving…”:“Save Case”} primary onClick={submit} disabled={saving}/>
</div>
</div>
</div>
);
}

// ── CONFIRM DELETE ────────────────────────────────────────────────────────────
function ConfirmDel({c,onConfirm,onCancel}) {
return (
<div onClick={onCancel} style={{position:“fixed”,inset:0,background:“rgba(0,0,0,.75)”,zIndex:300,display:“flex”,alignItems:“center”,justifyContent:“center”,padding:16}}>
<div onClick={e=>e.stopPropagation()} style={{background:”#111318”,border:“1px solid #2A2D38”,borderRadius:6,padding:28,maxWidth:400,width:“100%”,textAlign:“center”}}>
<div style={{fontSize:28,marginBottom:10}}>⚠</div>
<div style={{fontFamily:”‘Playfair Display’,serif”,fontSize:15,color:”#E8DFC0”,marginBottom:6}}>Delete this case?</div>
<div style={{fontSize:12,color:”#8892A0”,marginBottom:16}}>{c.caption}<br/><span style={{color:”#6B7280”}}>{c.id}</span></div>
<div style={{fontSize:11,color:”#EF4444”,background:”#EF444412”,border:“1px solid #EF444430”,borderRadius:3,padding:“8px 12px”,marginBottom:16}}>This removes the record from the dashboard.</div>
<div style={{display:“flex”,gap:8,justifyContent:“center”}}>
<button onClick={onCancel} style={{background:”#161820”,border:“1px solid #2A2D38”,color:”#C8CDD8”,padding:“7px 16px”,borderRadius:3,cursor:“pointer”,fontFamily:”‘DM Mono’,monospace”,fontSize:11}}>Cancel</button>
<button onClick={onConfirm} style={{background:”#EF444412”,border:“1px solid #EF444440”,color:”#EF4444”,padding:“7px 16px”,borderRadius:3,cursor:“pointer”,fontFamily:”‘DM Mono’,monospace”,fontSize:11}}>Delete</button>
</div>
</div>
</div>
);
}
