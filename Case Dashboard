function uid() { return “CVD-” + Math.floor(Math.random()*900+100); }
function today() { return new Date().toISOString().slice(0,10); }
function daysUntil(ds) {
if (!ds) return null;
const t = new Date(); t.setHours(0,0,0,0);
return Math.round((new Date(ds)-t)/86400000);
}
function urg(d) {
if (d===null) return “none”;
if (d<0) return “overdue”;
if (d<=7) return “critical”;
if (d<=21) return “warning”;
return “ok”;
}

const URG_STYLE = {
overdue:{bg:”#EF444422”,color:”#EF4444”},
critical:{bg:”#F59E0B22”,color:”#F59E0B”},
warning:{bg:”#6B8CFF22”,color:”#6B8CFF”},
ok:{bg:”#34D39920”,color:”#34D399”},
none:{bg:”#6B728020”,color:”#6B7280”},
};

function Badge({dateStr}) {
const d=daysUntil(dateStr), u=urg(d);
const s=URG_STYLE[u];
if (d===null) return <span style={{...pill,background:s.bg,color:s.color}}>No deadline</span>;
return <span style={{...pill,background:s.bg,color:s.color}}>{d<0?`${Math.abs(d)}d overdue`:d===0?“Today”:`${d}d`}</span>;
}

const pill={display:“inline-flex”,alignItems:“center”,borderRadius:3,fontSize:10,fontWeight:500,padding:“2px 7px”,letterSpacing:”.05em”,textTransform:“uppercase”};

